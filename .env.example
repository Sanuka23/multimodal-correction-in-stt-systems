# Must match screenapp-backend SESSION_SECRET for JWT verification
SESSION_SECRET=your-session-secret-here

# MongoDB (same instance as screenapp-backend)
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_DATABASE=screenapp
MONGO_DASHBOARD_DATABASE=asr_correction_dashboard

# Server
API_PORT=8000

# Model (optional overrides)
# ASR_CORRECTION_ADAPTER_PATH=./asr_correction/adapters
# ASR_CORRECTION_MODEL_PATH=./asr_correction/model_weights

# ScreenApp API (for training data generation)
# Create a PAT in ScreenApp Settings → API → Personal Access Tokens
SCREENAPP_API_URL=http://localhost:8081/v2
SCREENAPP_PAT_TOKEN=your-pat-token-here
SCREENAPP_TEAM_ID=your-team-id
SCREENAPP_FOLDER_ID=your-folder-id

# AVSR (optional)
# AUTO_AVSR_DIR=./models/auto_avsr
# AVSR_MODE=mediapipe
